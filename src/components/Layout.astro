---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'A NY-specific resource for parents asking questions about K-5 school-issued device programs. Informational, not legal advice.',
  noindex = false,
} = Astro.props;

const fullTitle = title === 'NoChrome' ? title : `${title} — NoChrome`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-stone-200 bg-white">
      <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="font-serif text-lg font-semibold text-stone-900 no-underline hover:text-stone-700">
          NoChrome <span class="text-stone-400 font-sans font-normal text-sm">/ NY</span>
        </a>
        <nav class="text-sm flex gap-4">
          <a href="/districts/">Districts</a>
          <a href="/opt-out/">Opt out</a>
          <a href="/research/">Research</a>
          <a href="/foil/">FOIL</a>
          <a href="/search/" aria-label="Search">Search</a>
        </nav>
      </div>
    </header>

    <main class="flex-1" data-pagefind-body>
      <slot />
    </main>

    <footer class="border-t border-stone-200 bg-white mt-16">
      <div class="max-w-3xl mx-auto px-4 py-6 text-sm text-stone-600">
        <p>Built by parents in NY. No tracking. No accounts. No cookies.</p>
        <p class="mt-2">
          <a href="/about/">About</a> · <a href="/board-meetings/">Board meetings</a> · <a href="/alternatives/">Alternatives</a>
        </p>
        <p class="mt-3 text-xs text-stone-500">
          This site provides information, not legal advice. Consult an education attorney for specific situations.
        </p>
      </div>
    </footer>
  </body>
</html>
